---
export const prerender = true;

// components
import Layout from "../layouts/Layout.astro";
import Portfolio from "../components/Portfolio";

// others
import { urlFor } from "../sanity/client";
import { getSections } from "../sanity/queries";
import { sectionNumber, type Photo } from "../sanity/types";
import type { PortfolioData } from "../types";
import "../styles/portfolio.css";

const cover = (photo: Photo, width: number, height: number) =>
  urlFor(photo.image).width(width).height(height).fit("crop").auto("format").url();
const contain = (photo: Photo, width: number) => urlFor(photo.image).width(width).auto("format").url();

const slug = (value: string) =>
  value
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const meta = (place?: string | null, year?: number | null): string => {
  if (place && year) return `${place} · ${String(year)}`;
  if (place) return place;
  if (year) return String(year);
  return "";
};

const sections = await getSections();

const portfolioData: PortfolioData = {
  sections: sections.map((section) => {
    const groups = (section.chapters ?? [])
      .map((chapter) => {
        const photos = chapter.photos ?? [];
        const heroPhoto = photos[0];
        if (!heroPhoto) return null;
        return {
          key: slug(chapter.title),
          title: chapter.title,
          meta: meta(chapter.place, chapter.year),
          hero: { full: cover(heroPhoto, 2400, 1350), thumb: cover(heroPhoto, 1400, 788), alt: heroPhoto.alt },
          frames: photos.slice(1).map((photo) => ({
            full: contain(photo, 2000),
            thumb: contain(photo, 800),
            alt: photo.alt,
          })),
        };
      })
      .filter((group) => group !== null);

    return {
      key: slug(section.title),
      number: sectionNumber(section),
      title: section.title,
      tagline: section.tagline ?? "",
      tags: section.tags ?? [],
      landing: section.landingHero?.image
        ? { src: cover(section.landingHero, 2000, 1400), alt: section.landingHero.alt }
        : null,
      groups,
    };
  }),
  contact: {
    name: "Marcin Kulbicki",
    email: "marcin.kulbicki@gmail.com",
    location: "Switzerland · Poland",
  },
};
---

<Layout title="Marcin Kulbicki — Photography">
  <Portfolio client:only="react" data={portfolioData}>
    <div class="viewport theme-a" slot="fallback"></div>
  </Portfolio>
</Layout>
